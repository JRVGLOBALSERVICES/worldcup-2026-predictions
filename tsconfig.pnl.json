{
  "compilerOptions": {
    "outDir": "/tmp/pnlbuild",
    "module": "commonjs",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": { "@/*": ["./*"] },
    "noEmit": false,
    "incremental": false
  },
  "include": ["__pnl_runner.ts", "lib/**/*.ts", "data/*.json"]
}
